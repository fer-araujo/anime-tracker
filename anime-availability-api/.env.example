# ── Server ──────────────────────────────────────────────
PORT=3000                         # Server port (default: 3000)

# ── TMDB (The Movie Database) ──────────────────────────
# Get your API key: https://www.themoviedb.org/settings/api
# Request a JWT Bearer token (v4 auth) from the same page
TMDB_KEY=                         # TMDB API JWT Bearer token (REQUIRED)

# ── AniList ─────────────────────────────────────────────
ANILIST_URL=https://graphql.anilist.co   # AniList GraphQL endpoint

# ── Streaming Availability (RapidAPI) ───────────────────
# Get your API key: https://rapidapi.com/movie-of-the-night/api/streaming-availability
# STREAMING_AVAIL_KEY and RAPIDAPI_KEY are accepted as fallback aliases
STREAMING_AVAILABILITY_KEY=        # RapidAPI key for streaming provider data

# ── MyAnimeList ─────────────────────────────────────────
# Register your app: https://myanimelist.net/apiconfigurations
MAL_CLIENT_ID=                     # MAL API Client ID (for enrichment)

# ── Cache (Upstash Redis) ───────────────────────────────
# Optional — falls back to in-memory cache if not configured
# Create a free Redis instance: https://console.upstash.com
REDIS_URL=                         # Upstash Redis REST URL
REDIS_TOKEN=                       # Upstash Redis REST API token

# ── Cache TTL Overrides (seconds) ───────────────────────
CACHE_TTL_HERO=21600               # Hero endpoint (default: 21600 = 6h)
CACHE_TTL_SEASON=21600             # Season endpoint (default: 21600 = 6h)
CACHE_TTL_ANIME=7200               # Anime details (default: 7200 = 2h)
CACHE_TTL_TMDB_IMAGES=86400        # TMDB image results (default: 86400 = 24h)
CACHE_TTL_TMDB_SEARCH=86400        # TMDB search results (default: 86400 = 24h)

# ── Circuit Breaker ─────────────────────────────────────
# Set to "true" to bypass the circuit breaker (not recommended in production)
DISABLE_CIRCUIT_BREAKER=false

# ── Regional Defaults ───────────────────────────────────
DEFAULT_COUNTRY=MX                 # ISO 3166-1 alpha-2 for streaming providers
